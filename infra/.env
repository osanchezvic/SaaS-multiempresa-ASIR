# .env for infra services
# Manage sensitive information for global infrastructure components.

# Grafana
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change_me_securely
# NPM_DB_USER=npm
# NPM_DB_PASSWORD=change_me_securely
# NPM_DB_NAME=npm

# Nginx Proxy Manager
NPM_HOST_PORT_80=80
NPM_HOST_PORT_443=443
NPM_HOST_PORT_81=81

# Fail2ban
F2B_LOG_LEVEL=INFO
F2B_DB_PURGE_AGE=30d

# Watchtower
# WATCHTOWER_CLEANUP=true
