# .env for infra services
# Manage sensitive information for global infrastructure components.

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_secure_password_change_me

# Nginx Proxy Manager Database
NPM_DB_HOST=db
NPM_DB_PORT=3306
NPM_DB_USER=npm
NPM_DB_PASSWORD=npm_secure_password_change_me
NPM_DB_ROOT_PASSWORD=root_secure_password_change_me
NPM_DB_NAME=npm


# Nginx Proxy Manager
NPM_HOST_PORT_80=80
NPM_HOST_PORT_443=443
NPM_HOST_PORT_81=81

# Fail2ban
F2B_LOG_LEVEL=INFO
F2B_DB_PURGE_AGE=30d

# Authelia Secrets
AUTHELIA_JWT_SECRET=super_secret_jwt_key_change_me_now_123456789
AUTHELIA_SESSION_SECRET=a_very_long_random_string_replace_with_something_secure_12345
AUTHELIA_STORAGE_ENCRYPTION_KEY=super_secure_storage_encryption_key_32chars_min
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=another_secret_key_for_identity_reset
API_TOKEN=supersecrettoken

