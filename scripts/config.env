# =========================================
# CONFIGURACIÓN SIMPLE
# =========================================

# Directorios
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROYECTO_ROOT="$(dirname "$SCRIPT_PATH")"
CATALOGO_DIR="$PROYECTO_ROOT/catalogo"
DB_DIR="$SCRIPT_PATH/databases"
CREDENTIALS_DIR="$DB_DIR/credentials"
LOG_DIR="$SCRIPT_PATH/logs"
DATA_DIR="$PROYECTO_ROOT/data"

# Puertos: rango para asignar (8000-8999)
PUERTO_MIN=8000
PUERTO_MAX=8999

# Modo forzado (sin confirmaciones)
FORCE_MODE=0

# Debug
DEBUG=${DEBUG:-0}

# Colores para terminal
COLOR_RED='\033[0;31m'
COLOR_GREEN='\033[0;32m'
COLOR_YELLOW='\033[1;33m'
COLOR_RESET='\033[0m'

